{
  "manifest_version": 3,
  "name": "Custom New Tab",
  "version": "1.0.0",
  "description": "Your personalized new tab with Minimalistic and Work themes.",
  "chrome_url_overrides": {
    "newtab": "newtab.html"
  },
  "permissions": [
    "storage",
    "geolocation",
    "history",
    "tabs"
  ],
  "host_permissions": [
    "https://www.youtube-nocookie.com/*",
    "https://www.youtube.com/*",
    "https://api.open-meteo.com/*",
    "https://generativelanguage.googleapis.com/*",
    "https://ice2.somafm.com/*",
    "https://ice6.somafm.com/*",
    "https://lfhh.radioca.st/*",
    "https://lofiradio.ru/*",
    "https://radio.solarmusic.one/*",
    "https://www.google.com/*"
  ],
  "content_security_policy": {
    "extension_pages": "script-src 'self'; object-src 'self'; media-src https://ice2.somafm.com https://ice6.somafm.com https://lfhh.radioca.st https://lofiradio.ru https://radio.solarmusic.one; frame-src https://www.youtube-nocookie.com https://www.youtube.com;"
  },
  "action": {
    "default_popup": "popup/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "32": "icons/icon32.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    },
    "default_title": "Custom New Tab Settings"
  },
  "icons": {
    "16": "icons/icon16.png",
    "32": "icons/icon32.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
